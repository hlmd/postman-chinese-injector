{
  "name": "postman-chinese-injector",
  "version": "1.0.3",
  "description": "把中文翻译注入 Postman 桌面端 / 网页版的非官方第三方汉化工具（跨平台 CLI + 浏览器扩展）。与 Postman, Inc. 无关。",
  "bin": {
    "postman-chinese-injector": "postman-chinese-injector.js"
  },
  "main": "postman-chinese-injector.js",
  "type": "commonjs",
  "scripts": {
    "patch": "node postman-chinese-injector.js",
    "restore": "node postman-chinese-injector.js --restore",
    "build:data": "node scripts/build-data.js",
    "build:ext": "node scripts/build-extension.js",
    "build:compress": "node scripts/compress-dist.js",
    "build:runtimes": "node scripts/fetch-runtimes.js",
    "build:win": "node scripts/build-bin.js bun-windows-x64 dist/postman-chinese-injector-win-x64.exe",
    "build:linux": "node scripts/build-bin.js bun-linux-x64 dist/postman-chinese-injector-linux-x64",
    "build:linux-arm64": "node scripts/build-bin.js bun-linux-arm64 dist/postman-chinese-injector-linux-arm64",
    "build:mac": "node scripts/build-bin.js bun-darwin-x64 dist/postman-chinese-injector-macos-x64",
    "build:mac-arm64": "node scripts/build-bin.js bun-darwin-arm64 dist/postman-chinese-injector-macos-arm64",
    "build": "npm run build:data && npm run build:win && npm run build:linux && npm run build:linux-arm64 && npm run build:mac && npm run build:mac-arm64"
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "@electron/asar": "^4.0.0"
  },
  "files": [
    "postman-chinese-injector.js",
    "pm-chinese.js",
    "locales/"
  ],
  "license": "MIT"
}
